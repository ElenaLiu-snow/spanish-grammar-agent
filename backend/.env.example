# LLM 提供商选择: anthropic, deepseek
LLM_PROVIDER=deepseek

# DeepSeek API 配置 (OpenAI 兼容)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 本地开发端口
FRONTEND_PORT=3001
BACKEND_PORT=8001

# 前端访问来源。线上部署后加入你的正式域名，例如:
# FRONTEND_ORIGINS=https://your-site.vercel.app,http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Anthropic 备用配置（仅当 LLM_PROVIDER=anthropic 时使用）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3.5-sonnet-20241022
# ANTHROPIC_AUTH_TOKEN=your_token
# ANTHROPIC_BASE_URL=http://127.0.0.1:15721
